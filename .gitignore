# build26-repo-template

Template files will not be tracked by git.
*.bak
*.tmp

# Source materials folder — contents excluded, README tracked
_remove-before-publish/*
!_remove-before-publish/README.md

# OS files
.DS_Store
Thumbs.db

# IDE files (except .vscode/mcp.json which we want)
.idea/
*.swp
*.swo

# Environment files with secrets
.env
.env.local
.env.*.local

# Dependencies (if applicable)
node_modules/
__pycache__/
*.pyc
.venv/

# Do not commit (staging only)
.do_not_commit/

# Per-learner workshop state (regenerated from template each run)
workshop/progress.json

# Per-learner Foundry workspace state — fully regenerated every run.
# The .foundry/ folder is a local CACHE created by the Foundry skill
# (datasets, evaluators, results, agent-metadata) from canonical sources:
#   - seed eval dataset:  data/jsonl/evaluation_data.jsonl
#   - custom evaluators:  data/evaluators/
# Never commit it — nothing required for a fresh run should live only here.
**/.foundry/
